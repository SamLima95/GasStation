note as AUDIT_TITLE #FFEEDD
  <b><size:14>AUDIT SERVICE (audit_db)</size></b>
end note

note as T_AUDITORIA
  <b>AUDITORIA</b> (tabela: auditoria) - Append-only (somente INSERT e SELECT)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do registro de auditoria |
  | servico | varchar | 80 | NN | - | Nome do microservico que gerou o evento |
  | entidade | varchar | 80 | NN | - | Tipo da entidade afetada (ex: Pedido, Cliente) |
  | entidade_id | uuid | 36 | NN | - | ID da entidade afetada |
  | acao | varchar | 50 | NN | - | Acao realizada (CREATE, UPDATE, DELETE) |
  | usuario_id | uuid | 36 | ref | NULL | Usuario responsavel (ref users.id), null se sistema |
  | unidade_id | uuid | 36 | ref | NULL | Contexto da unidade (ref unidades.id) |
  | detalhes | jsonb | variavel | - | NULL | Dados adicionais do evento (before/after) |
  | occurred_at | timestamp | - | NN | - | Momento real em que o evento ocorreu |
  | created_at | timestamp | - | NN | now() | Momento de persistencia no audit-service |
  Indices: INDEX(servico), INDEX(entidade, entidade_id), INDEX(usuario_id), INDEX(unidade_id), INDEX(occurred_at)
end note

T_CAIXA -[hidden]-> T_CONTA_A_RECEBER
T_CONTA_A_RECEBER -[hidden]-> T_AUDITORIA

