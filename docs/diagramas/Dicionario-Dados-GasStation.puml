@startuml Dicionario-Dados-GasStation
title GasStation - Dicionario de Dados Completo
caption Baseado nos schemas Prisma (PostgreSQL) | Atualizado em 2026-04-09

skinparam NoteBackgroundColor #FEFEFE
skinparam NoteBorderColor #999999
skinparam NoteFontSize 11
skinparam DefaultFontSize 11

note as LEGENDA
  <b>Convencoes</b>
  PK = Chave Primaria | FK = Chave Estrangeira
  NN = NOT NULL | UQ = Unico | DEF = Valor Padrao
  ref = referencia cross-service (sem FK fisico)
end note

note as IDENTITY_TITLE #CCCCFF
  <b><size:14>IDENTITY SERVICE (identity_db)</size></b>
end note

note as T_USUARIO
  <b>USUARIO</b> (tabela: users)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do usuario |
  | email | varchar | 255 | NN, UQ | - | Email de acesso do usuario |
  | name | varchar | 255 | NN | - | Nome completo do usuario |
  | role | varchar | 50 | NN | "user" | Papel do usuario (user, admin) |
  | created_at | timestamp | - | NN | - | Data e hora de criacao do registro |
end note

note as T_AUTH_CREDENTIAL
  <b>AUTH_CREDENTIAL</b> (tabela: auth_credentials)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico da credencial |
  | user_id | uuid | 36 | FK, NN, UQ | - | Referencia ao usuario (users.id) |
  | password_hash | varchar | 255 | NN | - | Hash bcrypt da senha do usuario |
end note

note as T_OAUTH_ACCOUNT
  <b>OAUTH_ACCOUNT</b> (tabela: oauth_accounts)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico da conta OAuth |
  | user_id | uuid | 36 | FK, NN | - | Referencia ao usuario (users.id) |
  | provider | varchar | 30 | NN | - | Provedor OAuth (google, github) |
  | provider_id | varchar | 255 | NN | - | ID do usuario no provedor externo |
  | created_at | timestamp | - | NN | - | Data de vinculacao da conta |
  Restricao: UQ(provider, provider_id)
end note

note as T_UNIDADE
  <b>UNIDADE</b> (tabela: unidades)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico da unidade |
  | nome | varchar | 120 | NN | - | Nome da filial ou deposito |
  | tipo | varchar | 30 | NN | - | Tipo da unidade (filial, deposito) |
  | status | varchar | 20 | NN | "ativa" | Status operacional (ativa, inativa) |
  | created_at | timestamp | - | NN | - | Data de criacao do registro |
end note

note as T_USUARIO_UNIDADE
  <b>USUARIO_UNIDADE</b> (tabela: usuario_unidade)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do vinculo |
  | user_id | uuid | 36 | FK, NN | - | Referencia ao usuario (users.id) |
  | unidade_id | uuid | 36 | FK, NN | - | Referencia a unidade (unidades.id) |
  | nivel | varchar | 30 | NN | "operador" | Nivel de acesso (operador, gerente, admin_holding) |
  | created_at | timestamp | - | NN | - | Data de atribuicao do vinculo |
  Restricao: UQ(user_id, unidade_id)
end note

note as T_CONFIGURACAO_UNIDADE
  <b>CONFIGURACAO_UNIDADE</b> (tabela: configuracao_unidade)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico da configuracao |
  | unidade_id | uuid | 36 | FK, NN | - | Referencia a unidade (unidades.id) |
  | chave | varchar | 80 | NN | - | Chave do parametro de configuracao |
  | valor | varchar | 255 | NN | - | Valor do parametro |
  | created_at | timestamp | - | NN | - | Data da ultima atualizacao |
  Restricao: UQ(unidade_id, chave)
end note

note as T_OUTBOX
  <b>OUTBOX</b> (tabela: outbox)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do evento |
  | event_name | varchar | 120 | NN | - | Nome do evento de dominio |
  | payload | jsonb | variavel | NN | - | Dados do evento em JSON |
  | created_at | timestamp | - | NN | - | Data de criacao do evento |
  | published_at | timestamp | - | - | NULL | Data de publicacao (null = pendente) |
  Indice: INDEX(published_at)
end note

T_USUARIO -[hidden]-> T_AUTH_CREDENTIAL
T_AUTH_CREDENTIAL -[hidden]-> T_OAUTH_ACCOUNT
T_OAUTH_ACCOUNT -[hidden]-> T_UNIDADE
T_UNIDADE -[hidden]-> T_USUARIO_UNIDADE
T_USUARIO_UNIDADE -[hidden]-> T_CONFIGURACAO_UNIDADE
T_CONFIGURACAO_UNIDADE -[hidden]-> T_OUTBOX

newpage

note as CATALOG_TITLE #CCFFCC
  <b><size:14>CATALOG SERVICE (catalog_db)</size></b>
end note

note as T_ITEM
  <b>ITEM</b> (tabela: items)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do item |
  | name | varchar | 255 | NN | - | Nome do produto no catalogo |
  | price_amount | int | 4 bytes | NN | - | Valor do preco em centavos |
  | price_currency | varchar | 3 | NN | "BRL" | Moeda ISO 4217 (ex: BRL, USD) |
  | created_at | timestamp | - | NN | - | Data de criacao do item |
end note

note as ORDER_TITLE #FFFFCC
  <b><size:14>ORDER SERVICE (order_db)</size></b>
end note

note as T_CLIENTE
  <b>CLIENTE</b> (tabela: clientes)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do cliente |
  | nome | varchar | 150 | NN | - | Nome ou razao social do cliente |
  | documento | varchar | 20 | NN, UQ | - | CPF ou CNPJ do cliente |
  | limite_credito | decimal | (12,2) | NN | - | Limite maximo para compras a prazo |
  | saldo_devedor | decimal | (12,2) | NN | 0 | Total em aberto do cliente |
  | unidade_id | uuid | 36 | NN, ref | - | Unidade que atende o cliente (ref unidades.id) |
  | created_at | timestamp | - | NN | now() | Data de cadastro do cliente |
end note

note as T_PEDIDO
  <b>PEDIDO</b> (tabela: pedidos)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do pedido |
  | cliente_id | uuid | 36 | FK, NN | - | Cliente que realizou o pedido (clientes.id) |
  | unidade_id | uuid | 36 | NN, ref | - | Unidade de origem (ref unidades.id) |
  | status | enum | - | NN | PENDENTE | Estado do pedido: PENDENTE, CONFIRMADO, ENTREGUE, CANCELADO |
  | tipo_pagamento | enum | - | NN | - | Forma de pagamento: A_VISTA, FIADO, CARTAO, PIX |
  | valor_total | decimal | (12,2) | NN | - | Soma dos itens (quantidade x preco_unitario) |
  | data_pedido | timestamp | - | NN | now() | Data e hora de criacao do pedido |
  | data_entrega_prevista | timestamp | - | - | NULL | Previsao de entrega (opcional) |
end note

note as T_ITEM_PEDIDO
  <b>ITEM_PEDIDO</b> (tabela: itens_pedido)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do item do pedido |
  | pedido_id | uuid | 36 | FK, NN | - | Pedido pai (pedidos.id) |
  | vasilhame_id | uuid | 36 | NN, ref | - | Tipo de vasilhame (ref vasilhames.id) |
  | quantidade | int | 4 bytes | NN | - | Quantidade de unidades solicitadas |
  | preco_unitario | decimal | (12,2) | NN | - | Preco por unidade no momento da venda |
end note

note as T_NOTA_FISCAL
  <b>NOTA_FISCAL</b> (tabela: notas_fiscais)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico da nota fiscal |
  | pedido_id | uuid | 36 | FK, NN | - | Pedido vinculado (pedidos.id) |
  | chave_acesso | varchar | 44 | - | NULL | Chave de acesso da NF-e (44 digitos) |
  | status | enum | - | NN | PENDENTE | Estado: PENDENTE, AUTORIZADA, REJEITADA, FALHA |
  | tentativas | int | 4 bytes | NN | 0 | Numero de tentativas de emissao |
  | mensagem | varchar | 500 | - | NULL | Mensagem de erro ou rejeicao da SEFAZ |
  | created_at | timestamp | - | NN | now() | Data de criacao do registro |
end note

T_ITEM -[hidden]-> T_CLIENTE
T_CLIENTE -[hidden]-> T_PEDIDO
T_PEDIDO -[hidden]-> T_ITEM_PEDIDO
T_ITEM_PEDIDO -[hidden]-> T_NOTA_FISCAL

newpage

note as STOCK_TITLE #FFCCCC
  <b><size:14>STOCK SERVICE (stock_db)</size></b>
end note

note as T_VASILHAME
  <b>VASILHAME</b> (tabela: vasilhames)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do vasilhame |
  | tipo | varchar | 20 | NN | - | Classificacao (P13, P45, P20, etc.) |
  | descricao | varchar | 120 | NN | - | Descricao detalhada do vasilhame |
  | capacidade | float | 8 bytes | NN | - | Capacidade em kg (ex: 13.0, 45.0) |
  | created_at | timestamp | - | NN | now() | Data de cadastro |
end note

note as T_MOVIMENTACAO
  <b>MOVIMENTACAO_ESTOQUE</b> (tabela: movimentacoes_estoque)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico da movimentacao |
  | unidade_id | uuid | 36 | NN, ref | - | Unidade do estoque (ref unidades.id) |
  | vasilhame_id | uuid | 36 | FK, NN | - | Tipo de vasilhame (vasilhames.id) |
  | usuario_id | uuid | 36 | NN, ref | - | Responsavel pelo registro (ref users.id) |
  | pedido_id | uuid | 36 | ref | NULL | Pedido vinculado, se houver (ref pedidos.id) |
  | tipo_movimentacao | enum | - | NN | - | Tipo: ENTRADA, SAIDA, RETORNO, AVARIA, AJUSTE |
  | quantidade | int | 4 bytes | NN | - | Quantidade movimentada (sempre positivo) |
  | data_hora | timestamp | - | NN | now() | Data e hora da movimentacao |
end note

note as T_COMODATO
  <b>COMODATO</b> (tabela: comodatos)
  |= Nome da Coluna |= Tipo de Dados |= Tamanho |= Restricoes |= Valor Padrao |= Descricao |
  | id | uuid | 36 | PK, NN | uuid() | Identificador unico do comodato |
  | cliente_id | uuid | 36 | NN, ref | - | Cliente detentor (ref clientes.id) |
  | unidade_id | uuid | 36 | NN, ref | - | Unidade responsavel (ref unidades.id) |
  | vasilhame_id | uuid | 36 | FK, NN | - | Tipo de vasilhame (vasilhames.id) |
  | saldo_comodato | int | 4 bytes | NN | - | Qtd de vasilhames em posse do cliente |
  | atualizado_em | timestamp | - | NN | auto | Ultima atualizacao do saldo (auto-update) |
  Restricao: UQ(cliente_id, unidade_id, vasilhame_id)
end note

T_VASILHAME -[hidden]-> T_MOVIMENTACAO
T_MOVIMENTACAO -[hidden]-> T_COMODATO

newpage

