{
  "name": "lframework",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Exemplo DDD + Microserviços + Hexagonal (TypeScript, PostgreSQL, Redis, RabbitMQ)",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "test": "pnpm -r run test",
    "dev:identity": "pnpm --filter identity-service run dev",
    "dev:catalog": "pnpm --filter catalog-service run dev",
    "dev:stock": "pnpm --filter stock-service run dev",
    "dev:order": "pnpm --filter order-service run dev",
    "dev:financial": "pnpm --filter financial-service run dev",
    "dev:logistics": "pnpm --filter logistics-service run dev",
    "dev:audit": "pnpm --filter audit-service run dev",
    "dev:dashboard": "pnpm --filter dashboard-service run dev",
    "dev:api-docs": "pnpm --filter api-docs run dev",
    "dev:dashboard-ui": "pnpm --filter dashboard-ui run dev",
    "dev": "bash scripts/dev.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:fresh": "docker compose down -v && docker compose up -d",
    "migrate:all": "bash scripts/migrate-all.sh",
    "backup:postgres": "bash scripts/backup-postgres.sh",
    "restore:postgres": "bash scripts/restore-postgres.sh",
    "load-test": "tsx scripts/load-test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "glob": "^13.0.6",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  }
}
