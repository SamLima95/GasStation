{
  "name": "lframework",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Exemplo DDD + Microserviços + Hexagonal (TypeScript, PostgreSQL, Redis, RabbitMQ)",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "test": "pnpm -r run test",
    "dev:identity": "pnpm --filter identity-service run dev",
    "dev:catalog": "pnpm --filter catalog-service run dev",
    "dev:stock": "pnpm --filter stock-service run dev",
    "dev:api-docs": "pnpm --filter api-docs run dev",
    "dev": "pnpm run dev:identity & pnpm run dev:catalog & pnpm run dev:stock & pnpm run dev:api-docs",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:fresh": "docker-compose down -v && docker-compose up -d",
    "migrate:all": "bash scripts/migrate-all.sh",
    "load-test": "tsx scripts/load-test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "glob": "^13.0.6",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  }
}
