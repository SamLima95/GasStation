generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("IDENTITY_DATABASE_URL")
}

model UserModel {
  id             String               @id @default(uuid())
  email          String               @unique
  name           String
  role           String               @default("user")
  status         String               @default("active")
  createdAt      DateTime             @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  authCredential AuthCredentialModel?
  oauthAccounts  OAuthAccountModel[]
  unidades       UsuarioUnidadeModel[]

  @@map("users")
}

model RolePermissionModel {
  id         String   @id @default(uuid())
  role       String
  permission String
  createdAt  DateTime @map("created_at")

  @@unique([role, permission])
  @@map("role_permissions")
}

model AuthCredentialModel {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  passwordHash String   @map("password_hash")
  user         UserModel @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_credentials")
}

model OAuthAccountModel {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  provider   String   // "google" | "github"
  providerId String   @map("provider_id")
  createdAt  DateTime @map("created_at")
  user       UserModel @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model UnidadeModel {
  id        String   @id @default(uuid())
  nome      String
  tipo      String   // "filial" | "deposito"
  status    String   @default("ativa") // "ativa" | "inativa"
  createdAt DateTime @map("created_at")

  usuarios       UsuarioUnidadeModel[]
  configuracoes  ConfiguracaoUnidadeModel[]

  @@map("unidades")
}

model UsuarioUnidadeModel {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  unidadeId String   @map("unidade_id")
  nivel     String   @default("operador") // "operador" | "gerente" | "admin_holding"
  createdAt DateTime @map("created_at")

  user    UserModel    @relation(fields: [userId], references: [id], onDelete: Cascade)
  unidade UnidadeModel @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  @@unique([userId, unidadeId])
  @@map("usuario_unidade")
}

model ConfiguracaoUnidadeModel {
  id        String   @id @default(uuid())
  unidadeId String   @map("unidade_id")
  chave     String
  valor     String
  createdAt DateTime @map("created_at")

  unidade UnidadeModel @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  @@unique([unidadeId, chave])
  @@map("configuracao_unidade")
}

// Outbox table for reliable event publishing (Outbox Pattern). Rows are published by the outbox relay.
model OutboxModel {
  id         String   @id @default(uuid())
  eventName  String   @map("event_name")
  payload    Json     @db.JsonB
  createdAt  DateTime @map("created_at")
  publishedAt DateTime? @map("published_at")

  @@index([publishedAt])
  @@map("outbox")
}
