generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("AUDIT_DATABASE_URL")
}

/// Registro de auditoria imutável (append-only).
/// Não deve ter UPDATE ou DELETE — apenas INSERT e SELECT.
model AuditoriaModel {
  id          String   @id @default(uuid())
  servico     String
  entidade    String
  entidadeId  String   @map("entidade_id")
  acao        String
  usuarioId   String?  @map("usuario_id")
  unidadeId   String?  @map("unidade_id")
  detalhes    Json?    @db.JsonB
  occurredAt  DateTime @map("occurred_at")
  createdAt   DateTime @map("created_at") @default(now())

  @@index([servico])
  @@index([entidade, entidadeId])
  @@index([usuarioId])
  @@index([unidadeId])
  @@index([occurredAt])
  @@map("auditoria")
}
